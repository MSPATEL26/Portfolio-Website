# ─────────────────────────────────────────────────
# REQUIRED — App will not function without these
# ─────────────────────────────────────────────────

# Groq AI (powers KIRO chatbot)
GROQ_API_KEY=your-groq-api-key

# Upstash Redis (analytics dashboard + visitor tracking + lounge chat)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────────
# OPTIONAL — Features degrade gracefully without these
# ─────────────────────────────────────────────────

# Lounge admin token (for /api/visitors admin access)
LOUNGE_ADMIN_TOKEN=your-secret-admin-token

# VAPID keys (for push notifications — leave blank to disable)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Analytics breakdown (customize percentages)
ANALYTICS_COUNTRIES=India:45,USA:30,Germany:15,UK:10
ANALYTICS_OS=Windows:50,macOS:30,Linux:20
